    name
    description
    owner_id
    created_at
Issues Table
    Issue
    ------
    issue_id
    project_id
    title
    description
    status
    priority
    assignee_id
    reporter_id
    created_at
    updated_at
Comments Table
    Comment
    -------
    comment_id
    issue_id
    user_id
    comment_text
    created_at
Attachments Table
