from enum import Enum
from abc import ABC, abstractmethod


# ENUMS
class Symbol(Enum):
    X = "X"
    O = "O"


class GameStatus(Enum):
    IN_PROGRESS = 1
    DRAW = 2
    WIN = 3


# PLAYER
class Player:
    def __init__(self, name, symbol):
        self.name = name
        self.symbol = symbol


# CELL
class Cell:
    def __init__(self):
        self.symbol = None


# BOARD
class Board:
    def __init__(self, size):
        self.size = size
        self.grid = [[Cell() for _ in range(size)] for _ in range(size)]

    def place_move(self, row, col, symbol):
        if row < 0 or row >= self.size or col < 0 or col >= self.size:
            print("Out of bounds!")
            return False

        if self.grid[row][col].symbol is not None:
            print("Cell already occupied!")
            return False

        self.grid[row][col].symbol = symbol
        return True

    # ✅ THIS METHOD MUST EXIST INSIDE CLASS
    def print_board(self):
        for row in self.grid:
            print(" | ".join(cell.symbol.value if cell.symbol else "-" for cell in row))
        print()
    def is_full(self):
        return all(cell.symbol is not None for row in self.grid for cell in row)
    


# MOVE
class Move:
    def __init__(self, player, row, col):
        self.player = player
        self.row = row
        self.col = col


# STRATEGY
class WinningStrategy(ABC):
    @abstractmethod
    def check(self, board, move):
        pass


class RowStrategy(WinningStrategy):
    def check(self, board, move):
        return all(
            board.grid[move.row][c].symbol == move.player.symbol
            for c in range(board.size)
        )


class ColStrategy(WinningStrategy):
    def check(self, board, move):
        return all(
            board.grid[r][move.col].symbol == move.player.symbol
            for r in range(board.size)
        )


class DiagonalStrategy(WinningStrategy):
    def check(self, board, move):
        n = board.size
        sym = move.player.symbol

        if move.row == move.col:
            if all(board.grid[i][i].symbol == sym for i in range(n)):
                return True

        if move.row + move.col == n - 1:
            if all(board.grid[i][n - i - 1].symbol == sym for i in range(n)):
                return True

        return False


# GAME
class Game:
    def __init__(self, size):
        self.board = Board(size)
        self.players = [Player("P1", Symbol.X), Player("P2", Symbol.O)]
        self.turn = 0
        self.status = GameStatus.IN_PROGRESS
        self.strategies = [RowStrategy(), ColStrategy(), DiagonalStrategy()]

    def make_move(self, row, col):
        player = self.players[self.turn]

        if not self.board.place_move(row, col, player.symbol):
            print("Invalid move!")
            return

        move = Move(player, row, col)

        # check winner
        for strategy in self.strategies:
            if strategy.check(self.board, move):
                self.status = GameStatus.WIN
                self.board.print_board()
                print(f"{player.name} wins!")
                return

        # check draw
        if self.board.is_full():
            self.status = GameStatus.DRAW
            self.board.print_board()
            print("Game Draw!")
            return

        self.turn = 1 - self.turn


# DRIVER CODE
if __name__ == "__main__":
    game = Game(3)

    while game.status == GameStatus.IN_PROGRESS:
        game.board.print_board()
        try:
            row = int(input("Enter row (1-3): ")) - 1
            col = int(input("Enter col (1-3): ")) - 1
        except ValueError:
            print("Invalid input! Enter numbers only.")
            continue
        game.make_move(row, col)

