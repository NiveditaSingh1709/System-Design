from enum import Enum
from abc import ABC, abstractmethod


class Symbol(Enum):
    X = "X"
    O = "O"


class GameStatus(Enum):
    IN_PROGRESS = 1
    DRAW = 2
    WIN = 3


class Player:
    def __init__(self, name: str, symbol: Symbol):
        self.name = name
        self.symbol = symbol


class Board:
    def __init__(self, size: int):
        self.size = size
        # Plain None grid — no Cell wrapper needed
        self.grid: list[list[Symbol | None]] = [
            [None] * size for _ in range(size)
        ]

    def place_move(self, row: int, col: int, symbol: Symbol) -> bool:
        if not (0 <= row < self.size and 0 <= col < self.size):
            print("Out of bounds!")
            return False
        if self.grid[row][col] is not None:
            print("Cell already occupied!")
            return False
        self.grid[row][col] = symbol
        return True

    def print_board(self):
        for row in self.grid:
            print(" | ".join(s.value if s else "-" for s in row))
        print()


class WinningStrategy(ABC):
    @abstractmethod
    def check(self, board: Board, row: int, col: int, symbol: Symbol) -> bool:
        pass


class RowStrategy(WinningStrategy):
    def check(self, board: Board, row: int, col: int, symbol: Symbol) -> bool:
        # Only check the row that was just played — O(n) not O(n²)
        return all(board.grid[row][c] == symbol for c in range(board.size))


class ColStrategy(WinningStrategy):
    def check(self, board: Board, row: int, col: int, symbol: Symbol) -> bool:
        # Only check the column that was just played
        return all(board.grid[r][col] == symbol for r in range(board.size))


class DiagonalStrategy(WinningStrategy):
    def check(self, board: Board, row: int, col: int, symbol: Symbol) -> bool:
        n = board.size
        # Main diagonal — only relevant if move is on it
        if row == col and all(board.grid[i][i] == symbol for i in range(n)):
            return True
        # Anti-diagonal — only relevant if move is on it
        if row + col == n - 1 and all(board.grid[i][n - i - 1] == symbol for i in range(n)):
            return True
        return False


class Game:
    def __init__(self, size: int):
        self.board = Board(size)
        self.players = [Player("P1", Symbol.X), Player("P2", Symbol.O)]
        self.turn = 0
        self.status = GameStatus.IN_PROGRESS
        self.strategies: list[WinningStrategy] = [
            RowStrategy(), ColStrategy(), DiagonalStrategy()
        ]
        self._moves_made = 0  # O(1) draw detection — no board scan needed

    def make_move(self, row: int, col: int) -> bool:
        player = self.players[self.turn]

        if not self.board.place_move(row, col, player.symbol):
            return False

        self._moves_made += 1

        # Pass coordinates directly — no Move object allocation
        for strategy in self.strategies:
            if strategy.check(self.board, row, col, player.symbol):
                self.status = GameStatus.WIN
                self.board.print_board()
                print(f"{player.name} wins!")
                return True

        if self._moves_made == self.board.size ** 2:
            self.status = GameStatus.DRAW
            self.board.print_board()
            print("Game draw!")
            return True

        self.turn = 1 - self.turn
        return True


if __name__ == "__main__":
    game = Game(3)

    while game.status == GameStatus.IN_PROGRESS:
        game.board.print_board()
        try:
            row = int(input("Enter row (1-3): ")) - 1
            col = int(input("Enter col (1-3): ")) - 1
        except ValueError:
            print("Invalid input! Enter numbers only.")
            continue
        game.make_move(row, col)

