import threading
import time
from datetime import datetime, timedelta


# -----------------------------
# Entity
# -----------------------------
class URLMapping:
    def __init__(self, id, long_url, short_code, expiry_minutes=None):
        self.id = id
        self.long_url = long_url
        self.short_code = short_code
        self.created_at = datetime.utcnow()
        self.expiry_at = (
            self.created_at + timedelta(minutes=expiry_minutes)
            if expiry_minutes else None
        )
        self.click_count = 0

    def is_expired(self):
        if self.expiry_at is None:
            return False
        return datetime.utcnow() > self.expiry_at

    def increment_click(self):
        self.click_count += 1


# -----------------------------
# ID Generator (Thread Safe)
# -----------------------------
class IDGenerator:
    def __init__(self):
        self.lock = threading.Lock()
        self.counter = 1

    def get_next_id(self):
        with self.lock:
            current_id = self.counter
            self.counter += 1
        return current_id


# -----------------------------
# Base62 Encoder
# -----------------------------
class Base62Encoder:
    CHARSET = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
    BASE = len(CHARSET)

    @classmethod
    def encode(cls, number):
        if number == 0:
            return cls.CHARSET[0]

        result = []
        while number > 0:
            number, remainder = divmod(number, cls.BASE)
            result.append(cls.CHARSET[remainder])
        return ''.join(reversed(result))


# -----------------------------
# Repository Layer (In-Memory)
# -----------------------------
class URLRepository:
    def __init__(self):
        self.short_to_mapping = {}
        self.long_to_short = {}

    def save(self, mapping):
        self.short_to_mapping[mapping.short_code] = mapping
        self.long_to_short[mapping.long_url] = mapping.short_code

    def find_by_short_code(self, short_code):
        return self.short_to_mapping.get(short_code)

    def find_by_long_url(self, long_url):
        short_code = self.long_to_short.get(long_url)
        if short_code:
            return self.short_to_mapping.get(short_code)
        return None


# -----------------------------
# Service Layer
# -----------------------------
class URLShortenerService:
    def __init__(self):
        self.id_generator = IDGenerator()
        self.repository = URLRepository()

    def create_short_url(self, long_url, expiry_minutes=None):
        # Check duplicate
        existing = self.repository.find_by_long_url(long_url)
        if existing:
            return existing.short_code

        # Generate unique ID
        unique_id = self.id_generator.get_next_id()

        # Convert to Base62
        short_code = Base62Encoder.encode(unique_id)

        # Create mapping
        mapping = URLMapping(unique_id, long_url, short_code, expiry_minutes)

        # Save
        self.repository.save(mapping)

        return short_code

    def redirect(self, short_code):
        mapping = self.repository.find_by_short_code(short_code)

        if not mapping:
            raise ValueError("Short URL does not exist")

        if mapping.is_expired():
            raise ValueError("Short URL has expired")

        mapping.increment_click()
        return mapping.long_url
