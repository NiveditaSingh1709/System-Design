# service.py
import hashlib
from models import URL
from id_generator import IDGenerator
from utils import encode_base62
from cache import CacheService
from datetime import datetime

class URLService:

    def __init__(self, repository):
        self.repository = repository

    def create(self, long_url):
        url_hash = hashlib.sha256(long_url.encode()).hexdigest()

        existing = self.repository.find_by_hash(url_hash)
        if existing:
            return existing.short_code

        id_value = IDGenerator.generate()
        short_code = encode_base62(id_value)

        url = URL(
            id=id_value,
            short_code=short_code,
            long_url=long_url,
            long_url_hash=url_hash,
            created_at=datetime.utcnow()
        )

        self.repository.save(url)
        return short_code

    def get_long_url(self, short_code):

        # 1️⃣ Check cache
        cached = CacheService.get(short_code)
        if cached:
            return cached

        # 2️⃣ DB lookup
        url = self.repository.find_by_short_code(short_code)

        if not url or url.is_deleted:
            return None

        # 3️⃣ Cache it
        CacheService.set(short_code, url.long_url, ttl=3600)

        return url.long_url
