class URLShortener:
    def __init__(self):
        self.url_map = {}
        self.reverse_map = {}
        self.counter = 1

    def encode(self, long_url):
        if long_url in self.reverse_map:
            return self.reverse_map[long_url]

        short_code = self._base62(self.counter)
        self.url_map[short_code] = long_url
        self.reverse_map[long_url] = short_code
        self.counter += 1

        return short_code

    def decode(self, short_code):
        return self.url_map.get(short_code)

    def _base62(self, num):
        chars = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
        base = len(chars)
        result = ""
        while num:
            num, rem = divmod(num, base)
            result = chars[rem] + result
        return result
