# utils.py
import string

BASE62 = string.ascii_letters + string.digits

def encode_base62(num):
    if num == 0:
        return BASE62[0]

    arr = []
    base = len(BASE62)

    while num:
        num, rem = divmod(num, base)
        arr.append(BASE62[rem])

    arr.reverse()
    return ''.join(arr)
