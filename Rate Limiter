Sliding Window Version (Another Popular Interview Solution)






import time
from collections import deque


class SlidingWindowRateLimiter:

    def __init__(self, limit: int, window_size: int):
        self.limit = limit
        self.window_size = window_size
        self.user_requests = {}

    def allow_request(self, user_id: str) -> bool:

        current_time = time.time()

        if user_id not in self.user_requests:
            self.user_requests[user_id] = deque()

        queue = self.user_requests[user_id]

        # Remove expired timestamps
        while queue and current_time - queue[0] > self.window_size:
            queue.popleft()

        if len(queue) < self.limit:
            queue.append(current_time)
            return True

        return False
    
limiter = SlidingWindowRateLimiter(5, 10)

for i in range(7):
    if limiter.allow_request("user1"):
        print("Allowed")
    else:
        print("Blocked")


